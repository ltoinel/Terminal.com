{
  "name": "ludovic-toinel-com",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "Portail personnel ludovic.toinel.com — Astro + Tailwind CSS.",
  "author": "Ludovic Toinel",
  "license": "MIT",
  "homepage": "https://ludovic.toinel.com",
  "scripts": {
    "dev": "astro dev",
