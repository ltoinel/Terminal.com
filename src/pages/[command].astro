---
import Layout from '../layouts/Layout.astro';
import Dock from '../components/Dock.astro';
import Terminal from '../components/Terminal.astro';
import { routes, commandDefs, manToHtml, manMetaDescription, lastmod } from '../lib/content';
import { site } from '../site.config.ts';

// One static page per deep-linkable command / document. Opening the URL boots
// the terminal, which then runs `man <command>` (see terminal.ts). The terminal
// renders client-side, so we also emit the command's manual as server-rendered,
// crawlable HTML (visually hidden) — otherwise the page's only real content is a
// JSON blob, invisible to engines that don't run JS.
export function getStaticPaths() {
  const manByName = new Map(commandDefs.map((c) => [c.name, c.man || '']));
  // Only command names with their own page can be linked from "SEE ALSO".
  const linkable = new Set(routes.map((r) => r.slug));
  return routes.map((r) => {
    const man = manByName.get(r.slug) || '';
    // Commands derive their crawlable mirror from the man page; home documents
    // (no man) carry their markdown already rendered to HTML in `r.body`.
    const manHtml = man ? manToHtml(man, (n) => linkable.has(n)) : r.body || '';
    return {
      params: { command: r.slug },
      props: {
        label: r.title,
        desc: r.desc,
        manHtml,
        manDesc: man ? manMetaDescription(man) : '',
        dateModified: lastmod(r.slug),
      },
    };
  });
}

interface Props {
  /** Command name or document heading — the route title. */
  label: string;
  /** Command / document description — the route desc. */
  desc: string;
  /** Server-rendered manual HTML (empty for documents, which have no man page). */
  manHtml: string;
  /** Meta description taken from the man DESCRIPTION section (empty if none). */
  manDesc: string;
  /** Source file's last-modified date (YYYY-MM-DD), or null. */
  dateModified: string | null;
}
const { label, desc, manHtml, manDesc, dateModified } = Astro.props;

// <title> seeds from the route title. The meta description prefers the richer
// man DESCRIPTION; otherwise the short route desc plus a context suffix (kept
// under the snippet limit). These also feed Open Graph / Twitter via the Layout.
const title = `${label} — ${site.name}`;
const suffix = ` · terminal interactif de ${site.shell.host}`;
const fallback = desc.length + suffix.length <= 160 ? `${desc}${suffix}` : desc;
const description = manDesc || fallback;
---

<Layout title={title} description={description} breadcrumb={label} dateModified={dateModified}>
  <Terminal />

  <Dock />

  {/* Crawlable mirror of the manual the terminal renders on load. */}
  {manHtml && <article class="sr-only" set:html={manHtml} />}
</Layout>
