---
/**
 * schema.org structured data, emitted as a `<script type="application/ld+json">`
 * block in the document <head>, as a single `@graph`:
 *   - `Person`  — the site owner (identity, always present)
 *   - `WebSite` — the site itself, published by that Person (always present)
 *   - `ProfilePage` (home) / `WebPage` (sub-pages) — the current document, whose
 *     `mainEntity` / `about` is the Person (Google's profile-page markup)
 *   - `BreadcrumbList` — Home › <page>, only on sub-pages (when `breadcrumb` set)
 *
 * Self-contained: it reads the central `site.config.ts`, so identity changes in
 * one place propagate to the structured data.
 */
import { site, sameAs } from '../site.config.ts';

interface Props {
  /** The page `<title>` — used as the WebPage/ProfilePage `name`. */
  title: string;
  /** Leaf page label (command/document title). Omit on the home page. */
  breadcrumb?: string;
  /** Last-modified date (YYYY-MM-DD) for the page, if known. */
  dateModified?: string | null;
}
const { title, breadcrumb, dateModified } = Astro.props;

const PERSON_ID = `${site.url}/#person`;
const WEBSITE_ID = `${site.url}/#website`;
const here = new URL(Astro.url.pathname, site.url).href;
const isHome = !breadcrumb;

const person = {
  '@type': 'Person',
  '@id': PERSON_ID,
  name: site.name,
  givenName: site.firstName,
  familyName: site.lastName,
  gender: site.gender,
  url: `${site.url}/`,
  image: new URL(site.ogImage, site.url).href,
  jobTitle: site.role,
  description: site.bio,
  knowsAbout: site.knowsAbout,
  knowsLanguage: site.knowsLanguage,
  hasOccupation: {
    '@type': 'Occupation',
    name: site.role,
    skills: site.knowsAbout,
  },
  nationality: { '@type': 'Country', name: site.nationality },
  birthPlace: { '@type': 'Place', name: site.birthPlace },
  worksFor: { '@type': 'Organization', name: site.company, url: site.companyUrl },
  sameAs,
};

const website = {
  '@type': 'WebSite',
  '@id': WEBSITE_ID,
  url: `${site.url}/`,
  name: site.name,
  description: site.tagline,
  inLanguage: site.lang,
  publisher: { '@id': PERSON_ID },
};

// The current document: a `ProfilePage` on the home (Google's person-profile
// markup, mainEntity → Person), a plain `WebPage` on sub-pages.
const webpage = {
  '@type': isHome ? 'ProfilePage' : 'WebPage',
  '@id': `${here}#webpage`,
  url: here,
  name: title,
  isPartOf: { '@id': WEBSITE_ID },
  inLanguage: site.lang,
  primaryImageOfPage: new URL(site.ogImage, site.url).href,
  ...(isHome
    ? { mainEntity: { '@id': PERSON_ID } }
    : { about: { '@id': PERSON_ID }, breadcrumb: { '@id': `${here}#breadcrumb` } }),
  ...(dateModified ? { dateModified } : {}),
};

const graph: object[] = [person, website, webpage];

if (breadcrumb) {
  graph.push({
    '@type': 'BreadcrumbList',
    '@id': `${here}#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${site.url}/` },
      { '@type': 'ListItem', position: 2, name: breadcrumb, item: here },
    ],
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
