---
import { Icon } from 'astro-icon/components';
---

<button id="theme-toggle" type="button" aria-label="Changer le thème (CRT)" class="dock-item">
  <Icon name="lucide:square-terminal" />
  <span class="dock-label" id="theme-label">crt</span>
</button>

<script>
  import { THEMES, applyTheme, currentTheme } from '../lib/themes';

  const btn = document.getElementById('theme-toggle');
  const label = document.getElementById('theme-label');
  // `green` shows as "crt" in the button (its historical label).
  const display = (t: string) => (t === 'green' ? 'crt' : t);

  if (label) label.textContent = display(currentTheme());

  btn?.addEventListener('click', () => {
    const next = THEMES[(THEMES.indexOf(currentTheme()) + 1) % THEMES.length];
    applyTheme(next);
    if (label) label.textContent = display(next);
  });
</script>
