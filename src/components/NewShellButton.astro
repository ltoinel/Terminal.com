---
import { Icon } from 'astro-icon/components';
---

<button
  id="new-shell"
  type="button"
  aria-label="Ouvrir une nouvelle fenêtre shell"
  class="dock-item needs-js"
>
  <Icon name="lucide:plus" />
  <span class="dock-label">shell</span>
</button>

<script>
  import { spawnTerminal } from '../lib/terminal';
  document.getElementById('new-shell')?.addEventListener('click', () => spawnTerminal());
</script>
