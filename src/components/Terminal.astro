---
import { site, openLinks } from '../site.config.ts';

// Runtime config injected into the client shell (read back via #shell-cfg). It is
// tiny, so it stays inline; the large filesystem + command registry are fetched
// from /shell-fs.json and /shell-commands.json (cached, shared across pages).
const cfg = {
  ...site.shell,
  links: openLinks,
  // Identity surfaced by the `whoami` command — mirrored from the site config so
  // there is a single source of truth.
  profile: {
    name: site.name,
    role: site.role,
    company: site.company,
    nationality: site.nationality,
    knowsAbout: site.knowsAbout,
    url: site.url,
  },
};
const safe = (o: unknown) => JSON.stringify(o).replace(/</g, '\\u003c');
---

<section class="ssh-win needs-js" id="ssh" aria-label={`Terminal interactif — ${site.shell.host}`}>
  <header class="ssh-bar" id="ssh-bar">
    <span class="ssh-dots">
      <button
        type="button"
        class="ssh-ctl"
        data-act="close"
        style="background:#ff5f56"
        aria-label="Fermer la session"></button>
      <button
        type="button"
        class="ssh-ctl"
        data-act="min"
        style="background:var(--amber)"
        aria-label="Réduire"></button>
      <button
        type="button"
        class="ssh-ctl"
        data-act="max"
        style="background:var(--green)"
        aria-label="Agrandir / restaurer"></button>
    </span>
    <span class="ssh-title">ssh — {site.shell.user}: ~</span>
    <span class="ssh-status"><span class="ssh-led"></span> connected</span>
  </header>

  <div class="ssh-body" id="ssh-body" role="log" aria-live="polite">
    <div class="ssh-output" id="ssh-output"></div>
    <div class="ssh-inputline" id="ssh-inputline" hidden>
      <span class="ssh-prompt" id="ssh-prompt"></span><span
        class="ssh-typed"
        id="ssh-typed"
        aria-hidden="true"></span>
      <input
        class="ssh-input"
        id="ssh-input"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="Saisir une commande"
      />
    </div>
  </div>

  <span class="ssh-grip" aria-hidden="true"></span>
</section>

<button type="button" class="ssh-reconnect needs-js" id="ssh-reconnect" hidden>
  ⏻ reconnect — ssh {site.shell.host}
</button>

<script type="application/json" id="shell-cfg" is:inline set:html={safe(cfg)} />

<script>
  import { bootTerminal } from '../lib/terminal';
  bootTerminal();
</script>
