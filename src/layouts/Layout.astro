---
import MatrixRain from '../components/MatrixRain.astro';
import JsonLd from '../components/JsonLd.astro';
import { site } from '../site.config.ts';
import { routes } from '../lib/content';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = `${site.name} — ${site.role} @ ${site.company}`, description = site.tagline } =
  Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL(site.ogImage, site.url).href;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {
      site.googleSiteVerification && (
        <meta name="google-site-verification" content={site.googleSiteVerification} />
      )
    }
    <meta name="theme-color" content="#080b09" />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={`Portrait de ${site.name}`} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />
    <meta property="profile:first_name" content={site.firstName} />
    <meta property="profile:last_name" content={site.lastName} />
    <meta property="profile:gender" content="male" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content={site.twitter} />
    <meta name="twitter:creator" content={site.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="me" href={site.wikidata} />
    <link rel="author" href="/humans.txt" />

    <!-- Fonts: VT323 (CRT) + IBM Plex Mono (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=VT323&display=swap"
    />

    <!-- schema.org structured data -->
    <JsonLd />

    <!-- Anti-FOUC: flag JS (reveals the terminal) and apply the theme
         (`.amber` only if chosen) before first paint -->
    <script is:inline>
      document.documentElement.classList.add('js');
      if (localStorage.getItem('theme') === 'amber') {
        document.documentElement.classList.add('amber');
      }
    </script>
  </head>

  <body>
    <!-- Matrix digital-rain background (green theme) -->
    <MatrixRain />

    <!-- Full-screen effects (purely decorative) -->
    <div class="fx-overlay fx-grain" aria-hidden="true"></div>
    <div class="fx-overlay fx-scanlines" aria-hidden="true"></div>
    <div class="fx-overlay fx-vignette" aria-hidden="true"></div>
    <div class="fx-overlay fx-flicker" aria-hidden="true"></div>

    <slot />

    <!-- Internal-link mesh, derived from the SAME `routes` array that feeds the
         sitemap. The terminal is keyboard-driven (no clickable links), so without
         this every command/document page would be an orphan for crawlers and
         screen readers. Visually hidden (.sr-only); fully indexable & accessible. -->
    <nav class="sr-only" aria-label="Plan du site">
      <a href="/">accueil</a>
      {
        routes.map((r) => (
          <a href={`/${r.slug}/`} title={r.desc}>
            {r.title}
          </a>
        ))
      }
    </nav>

    <!-- Update toast: shown when a new service worker is waiting (i.e. the site
         was redeployed with a new build version, see src/pages/sw.js.ts). -->
    <div id="sw-toast" role="status" aria-live="polite" hidden>
      <span>Nouvelle version disponible</span>
      <button type="button" id="sw-reload">Recharger</button>
    </div>

    <!-- Register the service worker: caches the shell data (shared across
         navigations) and enables Web Push. Best-effort, after load. When a new
         worker finishes installing while one is already in control, surface the
         toast; clicking "Recharger" tells it to skipWaiting, then reloads. -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js')
            .then((reg) => {
              const toast = document.getElementById('sw-toast');
              const reload = document.getElementById('sw-reload');

              // Reveal the toast and wire its button to the given waiting worker.
              const offer = (waiting) => {
                if (!waiting || !toast) return;
                toast.hidden = false;
                reload.onclick = () => {
                  reload.disabled = true;
                  waiting.postMessage({ type: 'SKIP_WAITING' });
                };
              };

              // A worker may already be waiting from a previous visit.
              if (reg.waiting && navigator.serviceWorker.controller) offer(reg.waiting);

              // Or one may install now: watch it reach "installed" while a worker
              // is already in control (an update, not the very first install).
              reg.addEventListener('updatefound', () => {
                const sw = reg.installing;
                if (!sw) return;
                sw.addEventListener('statechange', () => {
                  if (sw.state === 'installed' && navigator.serviceWorker.controller) offer(sw);
                });
              });
            })
            .catch(() => {});

          // The new worker took control after SKIP_WAITING — reload once to pick
          // up the fresh build. The guard avoids an infinite reload loop.
          let reloaded = false;
          navigator.serviceWorker.addEventListener('controllerchange', () => {
            if (reloaded) return;
            reloaded = true;
            location.reload();
          });
        });
      }
    </script>
  </body>
</html>
